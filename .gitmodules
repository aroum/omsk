[submodule "firmware/shared/lib/tinyusb"]
	path = firmware/shared/lib/tinyusb
	url = https://github.com/hathach/tinyusb.git
[submodule "firmware/shared/lib/u8g2"]
	path = firmware/shared/lib/u8g2
	url = https://github.com/olikraus/u8g2.git
[submodule "firmware/shared/lib/CMSIS-DSP"]
	path = firmware/shared/lib/CMSIS-DSP
	url = https://github.com/ARM-software/CMSIS-DSP.git
[submodule "firmware/shared/lib/pico_fft"]
	path = firmware/shared/lib/pico_fft
	url = https://github.com/pastaskrue/pico_fft.git
[submodule "firmware/shared/lib/pico_audio_i2s_32b"]
	path = firmware/shared/lib/pico_audio_i2s_32b
	url = https://github.com/elehobica/pico_audio_i2s_32b.git
[submodule "firmware/shared/lib/pico-extras"]
	path = firmware/shared/lib/pico-extras
	url = https://github.com/raspberrypi/pico-extras.git
